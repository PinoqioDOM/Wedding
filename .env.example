# Copy to .env.local and fill in with values from your Supabase project
# (Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — used by API routes / server actions for admin tasks
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site config
NEXT_PUBLIC_WEDDING_DATE=2026-09-12T16:00:00+02:00
NEXT_PUBLIC_COUPLE_NAMES="Amelia & Julian"
NEXT_PUBLIC_VENUE="Villa dei Fiori, Lake Como"
